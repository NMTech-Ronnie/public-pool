# bitcoin node running in your private network 192.168.1.0/24
BITCOIN_RPC_URL=http://192.168.1.100

# bitcoin node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your bitcoin.conf
#BITCOIN_RPC_URL=http://host.docker.internal

BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# You can use this instead of BITCOIN_RPC_USER and BITCOIN_RPC_PASSWORD
BITCOIN_RPC_COOKIEFILE=

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333

# PostgreSQL database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=publicpool
DB_PASSWORD=publicpool
DB_NAME=publicpool

# =============================================================================
# Scaling & Resource Configuration — TUNE FOR YOUR HARDWARE
# =============================================================================
#
# Recommended settings by hardware profile:
#
# ┌─────────────────┬──────────────┬────────────┬────────────────┬─────────────┐
# │ Hardware        │ INSTANCE_COUNT│ DB_POOL_MAX│ JOB_CACHE_TTL  │ Max Miners  │
# ├─────────────────┼──────────────┼────────────┼────────────────┼─────────────┤
# │ 4-core / 8GB    │ 2            │ 20         │ 120000 (2min)  │ ~2,000      │
# │ 8-core / 16GB   │ 5            │ 50         │ 120000 (2min)  │ ~5,000-8,000│
# │ 16-core / 32GB  │ 8-10         │ 80-100     │ 180000 (3min)  │ ~15,000+    │
# └─────────────────┴──────────────┴────────────┴────────────────┴─────────────┘
#
# INSTANCE_COUNT: Number of pool instances (replicas). Each Node.js process runs
# on a single event loop — use multiple instances to overcome single-core bottleneck.
# For 8-core servers, 5 instances leaves 3 cores for PostgreSQL + bitcoind.
#
# DB_POOL_MAX: Total max DB connections across ALL instances. Divide by
# INSTANCE_COUNT to get per-instance pool size (minimum 5 per instance).
#
# JOB_CACHE_TTL_MS: How long to keep mining job templates in memory.
# Lower = less memory usage, higher = less DB load on share validation.
#
# BITCOIN_POLL_MS: Leader-only. How often to poll bitcoind for new blocks.
# WORKER_POLL_MS: Worker-only. How often to poll chain_state table for height changes.

INSTANCE_COUNT=5
DB_POOL_MAX=50
JOB_CACHE_TTL_MS=120000
BITCOIN_POLL_MS=500
WORKER_POLL_MS=1000

# =============================================================================

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# mainnet | testnet
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Public-Pool"
