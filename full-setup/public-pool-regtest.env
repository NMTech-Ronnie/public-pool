BITCOIN_RPC_URL=http://bitcoin-regtest
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=28332
BITCOIN_RPC_TIMEOUT=10000

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=23334
STRATUM_PORT=23333

# PostgreSQL (via docker-compose network)
DB_HOST=postgres
DB_PORT=5432
DB_USER=publicpool
DB_PASSWORD=publicpool
DB_NAME=publicpool

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# mainnet | testnet
NETWORK=regtest

API_SECURE=false
