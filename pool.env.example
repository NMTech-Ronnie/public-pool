# Bitcoin Core RPC Configuration
BITCOIN_RPC_URL=http://bitcoind
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# Bitcoin ZMQ (optional, enable in bitcoin.conf)
# BITCOIN_ZMQ_HOST="tcp://bitcoind:3000"

# API & Stratum Ports
API_PORT=3334
STRATUM_PORT=3333

# PostgreSQL (docker-compose service name)
DB_HOST=postgres
DB_PORT=5432
DB_USER=publicpool
DB_PASSWORD=publicpool
DB_NAME=publicpool

# Network: mainnet | testnet | regtest
NETWORK=mainnet

# Optional: Telegram bot notifications
# TELEGRAM_BOT_TOKEN=

# Optional: Discord bot notifications
# DISCORD_BOT_CLIENTID=
# DISCORD_BOT_GUILD_ID=
# DISCORD_BOT_CHANNEL_ID=

# Optional: Developer fee address
# DEV_FEE_ADDRESS=

# HTTPS settings
API_SECURE=false

# Pool identifier for external share submissions
POOL_IDENTIFIER="Public-Pool"
